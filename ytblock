def cmd_install(args):
    """Full first-time setup."""
    print("\n  ytblock installer\n")

    if os.geteuid() != 0:
        print("  Error: install requires sudo. Run: sudo ytblock install")
        sys.exit(1)

    # Get the real user's home directory (not root's)
    real_user = os.environ.get("SUDO_USER", os.environ.get("USER"))
    real_home = os.path.expanduser(f"~{real_user}") if real_user else os.path.expanduser("~")
    real_base = os.path.join(real_home, ".youtube-blocker")

    os.makedirs(real_base, exist_ok=True)
    print("  [1/8] Created directory")

    # Copy script
    script_src = os.path.abspath(__file__)
    script_dst = os.path.join(real_base, "ytblock")
    if script_src != script_dst:
        import shutil
        shutil.copy2(script_src, script_dst)
    os.chmod(script_dst, 0o755)
    print("  [2/8] Installed script")

    # Copy bundled rickroll video
    video_dst = os.path.join(real_base, "rickroll.mp4")
    video_src = os.path.join(os.path.dirname(script_src), "rickroll.mp4")
    if not os.path.exists(video_dst):
        if os.path.exists(video_src):
            import shutil as _shutil
            _shutil.copy2(video_src, video_dst)
            print("  [3/8] Copied rickroll video")
        else:
            print("  Error: rickroll.mp4 not found next to the script.")
            print("  Make sure you're running install from the cloned repo directory.")
            sys.exit(1)
    else:
        print("  [3/8] Rickroll video already exists")

    # Generate certs
    cert_dst = os.path.join(real_base, "cert.pem")
    key_dst = os.path.join(real_base, "key.pem")
    if not os.path.exists(cert_dst):
        print("  [4/8] Generating SSL certificate...")
        san_entries = ",".join(f"DNS:{d}" for d in YOUTUBE_DOMAINS)
        name_constraints = ",".join(f"permitted;DNS:{d}" for d in YOUTUBE_DOMAINS)
        subprocess.run(
            [
                "openssl", "req", "-x509", "-new", "-nodes",
                "-keyout", key_dst,
                "-out", cert_dst,
                "-days", "3650",
                "-subj", "/CN=YTBlock CA",
                "-addext", f"subjectAltName={san_entries}",
                "-addext", "basicConstraints=critical,CA:TRUE",
                "-addext", f"nameConstraints=critical,{name_constraints}",
            ],
            check=True,
            capture_output=True,
        )
        os.chmod(key_dst, 0o600)
    else:
        print("  [4/8] Certificate already exists")

    # Trust cert
    print("  [5/8] Adding certificate to system keychain (may prompt for password)...")
    subprocess.run(
        [
            "security", "add-trusted-cert",
            "-d", "-r", "trustRoot",
            "-k", "/Library/Keychains/System.keychain",
            cert_dst,
        ],
        check=False,  # Don't fail if already trusted
    )

    # Write HTML
    html_dst = os.path.join(real_base, "rickroll.html")
    with open(html_dst, "w") as f:
        f.write(RICKROLL_HTML)
    print("  [6/8] Created rickroll page")

    # Initialize state
    state_dst = os.path.join(real_base, "state.json")
    if not os.path.exists(state_dst):
        with open(state_dst, "w") as f:
            json.dump({
                "rickroll_count": 0,
                "blocked": True,
                "unblock_until": None,
                "cooldown_started": None,
                "disable_step": 0,
                "installed_at": datetime.datetime.now().isoformat(),
            }, f, indent=2)

    # Fix ownership (files were created as root)
    if real_user:
        subprocess.run(["chown", "-R", real_user, real_base], capture_output=True)

    # Write hosts
    hosts_block()
    print("  [7/8] Blocked YouTube in /etc/hosts")

    # Write and load LaunchDaemon
    plist_content = PLIST_TEMPLATE.format(
        script_path=script_dst,
        log_path=os.path.join(real_base, "server.log"),
    )
    with open(PLIST_PATH, "w") as f:
        f.write(plist_content)

    # Unload first in case it's already loaded
    subprocess.run(["launchctl", "unload", PLIST_PATH], capture_output=True)
    subprocess.run(["launchctl", "load", PLIST_PATH], check=True)
    print("  [8/8] Started server daemon")

    # Symlink
    os.makedirs(os.path.dirname(SYMLINK_PATH), exist_ok=True)
    if os.path.exists(SYMLINK_PATH) or os.path.islink(SYMLINK_PATH):
        os.remove(SYMLINK_PATH)
    os.symlink(script_dst, SYMLINK_PATH)

    print(f"""
  Installation complete!

  YouTube is now blocked. Visiting youtube.com will show a rickroll.

  Commands:
    ytblock status    \u2014 Check current status
    ytblock disable   \u2014 Start 5-step unblock process
    sudo ytblock enable   \u2014 Re-block YouTube
    sudo ytblock uninstall \u2014 Remove everything

  Note for Firefox users: set security.enterprise_roots.enabled = true
  in about:config to avoid certificate warnings.
""")


def _run_uninstall_math():
    """Run 3 timed math problems for uninstall. Exits on failure."""
    print("  ━━━ Step 1/3: Math Problems ━━━\n")
    print("  Solve 3 problems. 3 attempts each. 30 seconds per problem.\n")
    problems = _generate_math_problems()[:3]
    for i, (question, answer, accept) in enumerate(problems, 1):
        solved = False
        for attempt in range(3):
            user_answer, timed_out = _timed_input(f"  [{i}/3] (30s) {question} > ")
            if user_answer is None or timed_out:
                msg = "Time's up!" if timed_out else ""
                print(f"  {msg} Uninstall aborted. ytblock stays installed.\n")
                sys.exit(1)
            user_answer = user_answer.strip()
            if user_answer in accept:
                print("  Correct!\n")
                solved = True
                break
            else:
                remaining = 2 - attempt
                if remaining > 0:
                    print(f"  Wrong. {remaining} attempt(s) left.\n")
                else:
                    print("  Wrong. Uninstall aborted. ytblock stays installed.\n")
        if not solved:
            sys.exit(1)


def _uninstall_typing(step_title, phrase, ack_msg):
    """Run a typing challenge. Returns True on success, 'paste' on paste detected."""
    print(f"  ━━━ {step_title} ━━━\n")
    print("  Type the following phrase EXACTLY (input is hidden):\n")
    print(f'  "{phrase}"\n')
    _enable_bracketed_paste()

    while True:
        print("  Start typing: ", end="", flush=True)
        pos = 0
        failed = False
        while pos < len(phrase):
            ch = read_char()
            if ch == "\x03":
                _disable_bracketed_paste()
                print("\n\n  Aborted. ytblock stays installed.")
                sys.exit(1)
            if ch == "\x16":  # Paste detected
                _disable_bracketed_paste()
                print("\n\n  Copy-paste detected. Back to math.\n")
                return "paste"
            if ch == "\x7f" or ch == "\x08":
                if pos > 0:
                    pos -= 1
                    print("\b \b", end="", flush=True)
                continue
            if ch == phrase[pos]:
                print("*", end="", flush=True)
                pos += 1
            else:
                print(f"\n\n  Mismatch at character {pos + 1}. Start over.\n")
                failed = True
                break
        if not failed:
            _disable_bracketed_paste()
            print(f"\n\n  {ack_msg}\n")
            return True


def _uninstall_friction():
    """Friction gate for uninstall: 3 math problems + guilt trip typing."""
    print("\n  You want to uninstall ytblock? Fine. But you'll have to earn it.\n")

    # Step 1: 3 math problems (30s timer)
    _run_uninstall_math()

    # Step 2 & 3: Typing challenges (paste = back to math)
    uninstall_phrases = [
        ("Step 2/3: Guilt Trip",
         "I am choosing to give up on my goals and let YouTube consume "
         "my time because I lack the discipline to keep this blocker installed",
         "...acknowledged."),
        ("Step 3/3: The Truth",
         "Kevin is the best there will ever be. Kevin is the smartest, "
         "handsome-st, hott-est human being there is. I LOVE KEVIIINNNN!!!!",
         "...damn right."),
    ]

    i = 0
    while i < len(uninstall_phrases):
        step_title, phrase, ack_msg = uninstall_phrases[i]
        result = _uninstall_typing(step_title, phrase, ack_msg)
        if result == "paste":
            _run_uninstall_math()
            i = 0  # restart typing from first phrase
            continue
        i += 1


def cmd_uninstall(args):
    """Remove everything."""
    if os.geteuid() != 0:
        print("  Error: uninstall requires sudo. Run: sudo ytblock uninstall")
        sys.exit(1)

    _uninstall_friction()

    print("\n  Uninstalling ytblock...\n")

    # Kill any orphaned reblock timer processes
    subprocess.run(
        ["pkill", "-f", "ytblock.*_reblock_timer"],
        capture_output=True,
    )

    # Unload daemon
    if os.path.exists(PLIST_PATH):
        subprocess.run(["launchctl", "unload", PLIST_PATH], capture_output=True)
        os.remove(PLIST_PATH)
        print("  Stopped and removed server daemon")

    # Remove hosts entries
    hosts_unblock()
    print("  Removed YouTube block from /etc/hosts")

    # Remove cert from keychain
    if os.path.exists(CERT_FILE):
        subprocess.run(
            ["security", "remove-trusted-cert", "-d", CERT_FILE],
            capture_output=True,
        )
        print("  Removed certificate from keychain")

    # Remove symlink
    if os.path.islink(SYMLINK_PATH):
        os.remove(SYMLINK_PATH)
        print("  Removed symlink")

    # Remove base directory
    import shutil
    if os.path.exists(BASE_DIR):
        shutil.rmtree(BASE_DIR)
        print("  Removed ~/.youtube-blocker")

    print("\n  ytblock uninstalled. YouTube is now accessible.\n")


