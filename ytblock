                break
            else:
                remaining = 2 - attempt
                if remaining > 0:
                    print(f"  Wrong. {remaining} attempt(s) left.\n")
                else:
                    print(f"  Wrong. Out of attempts. Restarting from step 1.\n")

        if not solved:
            # Reset to step 1
            state["disable_step"] = 0
            state["cooldown_started"] = None
            save_state(state)
            return False

    print("  All correct!")
    return True


def _generate_math_problems():
    """Generate 5 math problems with increasing difficulty."""
    problems = []

    # 1. Basic arithmetic
    a, b = random.randint(100, 999), random.randint(100, 999)
    ans = a + b
    problems.append((f"{a} + {b} = ?", ans, [str(ans)]))

    # 2. Multi-step arithmetic
    a, b, c = random.randint(10, 25), random.randint(10, 20), random.randint(10, 50)
    ans = (a * b) - c
    problems.append((f"({a} x {b}) - {c} = ?", ans, [str(ans)]))

    # 3. Basic algebra
    x = random.randint(2, 15)
    a = random.randint(2, 8)
    b = random.randint(1, 20)
    rhs = a * x + b
    problems.append((f"Solve for x: {a}x + {b} = {rhs}  ->  x = ?", x, [str(x)]))

    # 4. Quadratic (simple)
    x = random.randint(2, 6)
    a = random.randint(1, 3)
    rhs = a * x * x
    problems.append((
        f"Solve for x: {a}x\u00b2 = {rhs}  ->  x = ? (positive root)",
        x,
        [str(x)],
    ))

    # 5. Word problem
    speed1 = random.choice([40, 50, 60, 80])
    speed2 = random.choice([30, 40, 50, 60])
    dist1 = speed1 * random.randint(1, 3)
    dist2 = speed2 * random.randint(1, 3)
    time1 = dist1 / speed1
    time2 = dist2 / speed2
    total = int(time1 + time2)
    problems.append((
        f"A car drives {dist1}km at {speed1}km/h, then {dist2}km at {speed2}km/h. Total time in hours?",
        total,
        [str(total), str(float(total)), f"{total}.0"],
    ))

    return problems


def step4_journal(state):
    """Step 4: Write a 100+ word journal entry."""
    print("\n━━━ Step 4/5: Journaling ━━━\n")
    print("  Why do you want to unblock YouTube right now?")
    print("  Write at least 100 words. Be honest with yourself.")
    print("  Type your response and press Enter when done.\n")

    lines = []
    word_count = 0
    while word_count < 100:
        try:
            line = input("  > ")
        except (EOFError, KeyboardInterrupt):
            print("\n  Aborted.")
            sys.exit(1)
        lines.append(line)
        word_count = len(" ".join(lines).split())
        if word_count < 100:
            print(f"  ({word_count}/100 words \u2014 keep going)\n")

    entry = " ".join(lines)
    print(f"\n  Word count: {word_count}. Saved to journal.")

    # Append to journal (create with restricted permissions if new)
    if not os.path.exists(JOURNAL_FILE):
        fd = os.open(JOURNAL_FILE, os.O_CREAT | os.O_WRONLY, 0o600)
        os.close(fd)
    with open(JOURNAL_FILE, "a") as f:
        f.write(f"\n--- {datetime.datetime.now().isoformat()} ---\n")
        f.write(entry)
        f.write("\n")

    return True


def step5_physical(state):
    """Step 5: Physical challenge (honor system)."""
    print("\n━━━ Step 5/5: Physical Challenge ━━━\n")
    challenge, confirmation = random.choice(PHYSICAL_CHALLENGES)
    print(f"  {challenge}.\n")
    print(f'  When done, type exactly: "{confirmation}"\n')

    while True:
        try:
            response = input("  > ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n  Aborted.")
            sys.exit(1)

        if response == confirmation:
            print("\n  Well done!")
            return True
        else:
            print(f'  That doesn\'t match. Type exactly: "{confirmation}"\n')


def run_disable():
    """Run the 5-step friction-based disable process."""
    state = load_state()

    if not state.get("blocked", True):
        if state.get("unblock_until"):
            deadline = datetime.datetime.fromisoformat(state["unblock_until"])
            remaining = (deadline - datetime.datetime.now()).total_seconds()
            if remaining > 0:
                mins = int(remaining // 60)
                print(f"\n  YouTube is already unblocked. {mins} minutes remaining.")
                print(f"  Auto-reblocking at {deadline.strftime('%H:%M')}.\n")
                return
        print("\n  YouTube is not currently blocked.\n")
        return

    current_step = state.get("disable_step", 0)

    # Step 1: Cooldown
    if current_step < 1:
        if not step1_cooldown(state):
            return
        state["disable_step"] = 1
        save_state(state)
    elif current_step == 1:
        # Check if cooldown has passed
        if not step1_cooldown(state):
            return

    # Step 2: Typing
    if current_step < 2:
        state["disable_step"] = 2
        save_state(state)
    if state.get("disable_step", 0) <= 2:
        if not step2_typing(state):
            return
        state["disable_step"] = 3
        save_state(state)

    # Step 3: Math (30s timer per problem)
    if state.get("disable_step", 0) <= 3:
        if not step3_math(state):
            print("  Failed math. Progress reset to step 1.")
            return
        state["disable_step"] = 4
        save_state(state)

    # Step 4: Journal
    if state.get("disable_step", 0) <= 4:
        if not step4_journal(state):
            return
        state["disable_step"] = 5
        save_state(state)

    # Step 5: Physical
    if state.get("disable_step", 0) <= 5:
        if not step5_physical(state):
            return

    # All steps passed — unblock for 30 minutes
    unblock_until = datetime.datetime.now() + datetime.timedelta(seconds=UNBLOCK_SECONDS)
    state["blocked"] = False
    state["unblock_until"] = unblock_until.isoformat()
    state["disable_step"] = 0
    state["cooldown_started"] = None
    save_state(state)

    # Remove hosts block (needs sudo)
    print("\n  Removing YouTube block (requires sudo)...\n")
    subprocess.run(
        ["sudo", sys.executable, os.path.abspath(__file__), "_unblock_hosts"],
        check=True,
    )

    # Spawn background reblock timer
    subprocess.Popen(
        [sys.executable, os.path.abspath(__file__), "_reblock_timer", str(UNBLOCK_SECONDS)],
        start_new_session=True,
        stdout=open(os.devnull, "w"),
        stderr=open(os.devnull, "w"),
    )

    print(f"\n  YouTube unblocked for 30 minutes.")
    print(f"  Auto-reblocking at {unblock_until.strftime('%H:%M')}.")
    print(f"  Use this time wisely.\n")


