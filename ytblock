# ── State Management ───────────────────────────────────────────────────

def _default_state():
    return {
        "rickroll_count": 0,
        "blocked": True,
        "unblock_until": None,
        "cooldown_started": None,
        "disable_step": 0,
        "installed_at": None,
    }


def _acquire_lock(exclusive=False):
    """Acquire the state lock file. Returns the lock fd."""
    try:
        fd = os.open(STATE_LOCK, os.O_CREAT | os.O_RDWR, 0o666)
    except PermissionError:
        # Lock file owned by root — fix permissions if we're root, else use temp
        if os.geteuid() == 0:
            os.chmod(STATE_LOCK, 0o666)
            fd = os.open(STATE_LOCK, os.O_CREAT | os.O_RDWR, 0o666)
        else:
            # Fall back to no locking rather than crashing
            return None
    fcntl.flock(fd, fcntl.LOCK_EX if exclusive else fcntl.LOCK_SH)
    return fd


def _release_lock(fd):
    """Release and close the state lock file."""
    if fd is None:
        return
    fcntl.flock(fd, fcntl.LOCK_UN)
    os.close(fd)


def load_state():
    lock_fd = _acquire_lock(exclusive=False)
    try:
        if os.path.exists(STATE_FILE):
            with open(STATE_FILE, "r") as f:
                return json.load(f)
        return _default_state()
    finally:
        _release_lock(lock_fd)


def save_state(state):
    lock_fd = _acquire_lock(exclusive=True)
    try:
        tmp = STATE_FILE + ".tmp"
        fd = os.open(tmp, os.O_CREAT | os.O_WRONLY | os.O_TRUNC, 0o666)
        with os.fdopen(fd, "w") as f:
            json.dump(state, f, indent=2)
        os.replace(tmp, STATE_FILE)
    finally:
        _release_lock(lock_fd)


def update_state(fn):
    """Atomically read-modify-write state. fn(state) should mutate state and optionally return a value."""
    lock_fd = _acquire_lock(exclusive=True)
    try:
        if os.path.exists(STATE_FILE):
            with open(STATE_FILE, "r") as f:
                state = json.load(f)
        else:
            state = _default_state()
        result = fn(state)
        tmp = STATE_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(state, f, indent=2)
        os.replace(tmp, STATE_FILE)
        return result
    finally:
        _release_lock(lock_fd)


def increment_rickroll():
    def _inc(state):
        state["rickroll_count"] += 1
        return state["rickroll_count"]
    return update_state(_inc)


# ── Hosts File Management ─────────────────────────────────────────────

def hosts_block():
    """Add YouTube domains to /etc/hosts."""
    with open(HOSTS_PATH, "r") as f:
        content = f.read()

    # Remove existing block if present
    content = _remove_hosts_block(content)

    lines = [HOSTS_START]
    for domain in YOUTUBE_DOMAINS:
        lines.append(f"127.0.0.1  {domain}")
    lines.append(HOSTS_END)
    lines.append("")

    content = content.rstrip("\n") + "\n\n" + "\n".join(lines)

    with open(HOSTS_PATH, "w") as f:
        f.write(content)

    _flush_dns()


def hosts_unblock():
    """Remove YouTube domains from /etc/hosts."""
    with open(HOSTS_PATH, "r") as f:
        content = f.read()

    content = _remove_hosts_block(content)

    with open(HOSTS_PATH, "w") as f:
        f.write(content)

    _flush_dns()


def hosts_check():
    """Return True if hosts block is present."""
    with open(HOSTS_PATH, "r") as f:
        return HOSTS_START in f.read()


def _remove_hosts_block(content):
    lines = content.split("\n")
    result = []
    inside = False
    for line in lines:
        if HOSTS_START in line:
            inside = True
            continue
        if HOSTS_END in line:
            inside = False
            continue
        if not inside:
            result.append(line)
    # Clean up extra blank lines at the end
    while result and result[-1].strip() == "":
        result.pop()
    return "\n".join(result) + "\n"


def _flush_dns():
    subprocess.run(
        ["dscacheutil", "-flushcache"],
        capture_output=True,
    )
    subprocess.run(
        ["killall", "-HUP", "mDNSResponder"],
        capture_output=True,
    )


# ── Certificate Generation ────────────────────────────────────────────

def generate_certs():
    """Generate self-signed cert with SANs for all YouTube domains."""
    san_entries = ",".join(f"DNS:{d}" for d in YOUTUBE_DOMAINS)
    name_constraints = ",".join(f"permitted;DNS:{d}" for d in YOUTUBE_DOMAINS)
    subprocess.run(
        [
            "openssl", "req", "-x509", "-new", "-nodes",
            "-keyout", KEY_FILE,
            "-out", CERT_FILE,
            "-days", "3650",
            "-subj", "/CN=YTBlock CA",
            "-addext", f"subjectAltName={san_entries}",
            "-addext", "basicConstraints=critical,CA:TRUE",
            "-addext", f"nameConstraints=critical,{name_constraints}",
        ],
        check=True,
        capture_output=True,
    )
    os.chmod(KEY_FILE, 0o600)
    print("  Generated self-signed certificate")


def trust_cert():
    """Add cert to macOS system keychain as trusted."""
    subprocess.run(
        [
            "sudo", "security", "add-trusted-cert",
            "-d", "-r", "trustRoot",
            "-k", "/Library/Keychains/System.keychain",
            CERT_FILE,
        ],
        check=True,
    )
    print("  Added certificate to system keychain")


def untrust_cert():
    """Remove cert from macOS system keychain."""
    subprocess.run(
        [
            "sudo", "security", "remove-trusted-cert",
            "-d", CERT_FILE,
        ],
        capture_output=True,
    )


# ── HTTP/HTTPS Server ─────────────────────────────────────────────────

class RickrollHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        # Check if we should auto-reblock
        self._check_reblock()

        if self.path == "/rickroll.mp4" and os.path.exists(VIDEO_FILE):
            self._serve_video()
        elif self.path == "/count":
            self._serve_count()
        else:
            self._serve_rickroll()

    def do_HEAD(self):
        self._check_reblock()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
        self.end_headers()

    def do_POST(self):
        self.do_GET()

    def _serve_rickroll(self):
        if self.path in ("/", "/index.html"):
            count = increment_rickroll()
        html = RICKROLL_HTML
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
        content = html.encode("utf-8")
        self.send_header("Content-Length", str(len(content)))
        self.end_headers()
        self.wfile.write(content)

    def _serve_video(self):
        file_size = os.path.getsize(VIDEO_FILE)
        range_header = self.headers.get("Range")

        if range_header:
            # Handle Range requests for video seeking
            try:
                range_val = range_header.replace("bytes=", "").split(",")[0]  # first range only
                start_str, end_str = range_val.split("-")
                start = int(start_str) if start_str else max(0, file_size - int(end_str))
                end = min(int(end_str), file_size - 1) if end_str and start_str else file_size - 1
                if start < 0 or start >= file_size or end < start:
                    self.send_response(416)
                    self.send_header("Content-Range", f"bytes */{file_size}")
                    self.end_headers()
                    return
            except (ValueError, IndexError):
                self.send_response(416)
                self.send_header("Content-Range", f"bytes */{file_size}")
                self.end_headers()
                return

            length = end - start + 1

            self.send_response(206)
            self.send_header("Content-Type", "video/mp4")
            self.send_header("Content-Range", f"bytes {start}-{end}/{file_size}")
            self.send_header("Content-Length", str(length))
            self.send_header("Accept-Ranges", "bytes")
            self.end_headers()

            with open(VIDEO_FILE, "rb") as f:
                f.seek(start)
                remaining = length
                while remaining > 0:
                    chunk = f.read(min(65536, remaining))
                    if not chunk:
                        break
                    self.wfile.write(chunk)
                    remaining -= len(chunk)
        else:
            self.send_response(200)
            self.send_header("Content-Type", "video/mp4")
            self.send_header("Content-Length", str(file_size))
            self.send_header("Accept-Ranges", "bytes")
            self.end_headers()

            with open(VIDEO_FILE, "rb") as f:
                while True:
                    chunk = f.read(65536)
                    if not chunk:
                        break
                    self.wfile.write(chunk)

    def _serve_count(self):
        state = load_state()
        data = json.dumps({"count": state["rickroll_count"]}).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-cache")
        self.end_headers()
        self.wfile.write(data)

    def _check_reblock(self):
        state = load_state()
        if state.get("unblock_until"):
            deadline = datetime.datetime.fromisoformat(state["unblock_until"])
            if datetime.datetime.now() >= deadline:
                state["unblock_until"] = None
                state["blocked"] = True
                state["disable_step"] = 0
                state["cooldown_started"] = None
                save_state(state)
                if os.geteuid() == 0:
                    hosts_block()

    def log_message(self, format, *args):
        # Suppress default logging to stderr in daemon mode
        pass


class ReusableTCPServer(socketserver.TCPServer):
    allow_reuse_address = True


class ThreadedHTTPServer(socketserver.ThreadingMixIn, ReusableTCPServer):
    daemon_threads = True


def run_server():
    """Run HTTP (80) and HTTPS (443) servers."""
    # Periodic hosts check thread
    def hosts_watchdog():
        while True:
            time.sleep(60)
            try:
                state = load_state()
                if state.get("blocked", True) and not hosts_check():
                    hosts_block()
                    print(f"[{datetime.datetime.now()}] Hosts entries restored by watchdog")
            except Exception as e:
                print(f"[{datetime.datetime.now()}] Watchdog error: {e}")

    watchdog = threading.Thread(target=hosts_watchdog, daemon=True)
    watchdog.start()

    # HTTP server on port 80
    http_server = ThreadedHTTPServer(("127.0.0.1", 80), RickrollHandler)

    # HTTPS server on port 443
    https_server = ThreadedHTTPServer(("127.0.0.1", 443), RickrollHandler)
    if os.path.exists(CERT_FILE) and os.path.exists(KEY_FILE):
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(CERT_FILE, KEY_FILE)
        https_server.socket = ctx.wrap_socket(https_server.socket, server_side=True)

    print(f"[{datetime.datetime.now()}] ytblock server starting on ports 80 and 443")

    http_thread = threading.Thread(target=http_server.serve_forever, daemon=True)
    https_thread = threading.Thread(target=https_server.serve_forever, daemon=True)

    http_thread.start()
    https_thread.start()

    # Block main thread
    try:
        while True:
            time.sleep(3600)
    except (KeyboardInterrupt, SystemExit):
        http_server.shutdown()
        https_server.shutdown()
        print(f"\n[{datetime.datetime.now()}] Server stopped")


# ── Friction-Based Disable ─────────────────────────────────────────────

def _enable_bracketed_paste():
    """Enable bracketed paste mode — terminal wraps paste with escape sequences."""
    sys.stdout.write("\x1b[?2004h")
    sys.stdout.flush()


def _disable_bracketed_paste():
    """Disable bracketed paste mode."""
    sys.stdout.write("\x1b[?2004l")
    sys.stdout.flush()


def read_char():
    """Read a single character without echo. Detects paste via bracketed paste mode."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
        # Detect bracketed paste: terminal sends \x1b[200~ before paste
        if ch == "\x1b":
            # Check if this is the start of a paste bracket
            buf = ""
            while select.select([fd], [], [], 0.05)[0]:
                buf += sys.stdin.read(1)
                if buf == "[200~":
                    # Paste detected — drain until end bracket \x1b[201~
                    end_buf = ""
                    while True:
                        c = sys.stdin.read(1)
                        end_buf += c
                        if end_buf.endswith("\x1b[201~"):
                            break
                        # Keep only last 6 chars to match the end sequence
                        if len(end_buf) > 100:
                            end_buf = end_buf[-6:]
                    return "\x16"  # Paste detected sentinel
                if len(buf) > 5:
                    break
            # Not a paste bracket — just an escape key press
            return "\x1b"
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ch


def step1_cooldown(state):
    """Step 1: 30-minute cooldown timer."""
    print("\n━━━ Step 1/5: Cooldown Timer ━━━\n")

    if state.get("cooldown_started"):
        started = datetime.datetime.fromisoformat(state["cooldown_started"])
        elapsed = (datetime.datetime.now() - started).total_seconds()
        if elapsed < COOLDOWN_SECONDS:
            remaining = int(COOLDOWN_SECONDS - elapsed)
            mins, secs = divmod(remaining, 60)
            resume_time = started + datetime.timedelta(seconds=COOLDOWN_SECONDS)
            print(f"  Cooldown in progress. {mins}m {secs}s remaining.")
            print(f"  Run `ytblock disable` again after {resume_time.strftime('%H:%M')}.")
            return False
        else:
            print("  Cooldown complete!")
            return True
    else:
        state["cooldown_started"] = datetime.datetime.now().isoformat()
        state["disable_step"] = 1
        save_state(state)
        resume_time = datetime.datetime.now() + datetime.timedelta(seconds=COOLDOWN_SECONDS)
        print(f"  Starting 5-minute cooldown...")
        print(f"  Come back and run `ytblock disable` again after {resume_time.strftime('%H:%M')}.")
        return False


def step2_typing(state):
    """Step 2: Type a long confirmation string character by character."""
    print("\n━━━ Step 2/5: Type Confirmation ━━━\n")
    phrase = random.choice(CONFIRMATION_PHRASES)
    print("  Type the following phrase EXACTLY (input is hidden to prevent copy-paste):\n")
    print(f'  "{phrase}"\n')
    _enable_bracketed_paste()

    while True:
        print("  Start typing: ", end="", flush=True)
        pos = 0
        failed = False
        while pos < len(phrase):
            ch = read_char()
            if ch == "\x03":  # Ctrl+C
                print("\n\n  Aborted.")
                sys.exit(1)
            if ch == "\x16":  # Paste detected
                print("\n\n  Copy-paste detected. Nice try. Start over.\n")
                failed = True
                break
            if ch == "\x7f" or ch == "\x08":  # Backspace
                if pos > 0:
                    pos -= 1
                    print("\b \b", end="", flush=True)
                continue
            if ch == phrase[pos]:
                print("*", end="", flush=True)
                pos += 1
            else:
                print(f"\n\n  Mismatch at character {pos + 1}. Start over.\n")
                failed = True
                break
        if not failed:
            _disable_bracketed_paste()
            print("\n\n  Confirmed!")
            return True


def _timed_input(prompt, timeout=30):
    """Read input with a countdown timer. Returns (answer, timed_out)."""
    result = [None]
    timed_out = [False]

    def read_input():
        try:
            result[0] = input(prompt)
        except (EOFError, KeyboardInterrupt):
            result[0] = None

    t = threading.Thread(target=read_input, daemon=True)
    t.start()
    t.join(timeout)
    if t.is_alive():
        timed_out[0] = True
        print("\n\n  Time's up!")
        # Send a newline to unblock input()
        try:
            os.write(sys.stdin.fileno(), b"\n")
        except Exception:
            pass
        t.join(1)
    return result[0], timed_out[0]


