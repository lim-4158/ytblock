def cmd_status(args):
    """Show current status."""
    state = load_state()

    # Check and enforce auto-reblock
    if state.get("unblock_until"):
        deadline = datetime.datetime.fromisoformat(state["unblock_until"])
        if datetime.datetime.now() >= deadline:
            state["blocked"] = True
            state["unblock_until"] = None
            state["disable_step"] = 0
            state["cooldown_started"] = None
            save_state(state)
            if os.geteuid() == 0:
                hosts_block()

    blocked = state.get("blocked", True)
    count = state.get("rickroll_count", 0)

    print(f"\n  ytblock status")
    print("  " + "\u2501" * 30)
    print(f"  Status:    {'BLOCKED' if blocked else 'UNBLOCKED'}")
    print(f"  Rickrolls: {count}")

    if not blocked and state.get("unblock_until"):
        deadline = datetime.datetime.fromisoformat(state["unblock_until"])
        remaining = (deadline - datetime.datetime.now()).total_seconds()
        if remaining > 0:
            mins = int(remaining // 60)
            secs = int(remaining % 60)
            print(f"  Reblocks:  {deadline.strftime('%H:%M')} ({mins}m {secs}s)")

    if state.get("cooldown_started") and state.get("disable_step", 0) >= 1:
        started = datetime.datetime.fromisoformat(state["cooldown_started"])
        elapsed = (datetime.datetime.now() - started).total_seconds()
        if elapsed < COOLDOWN_SECONDS:
            remaining = int(COOLDOWN_SECONDS - elapsed)
            mins, secs = divmod(remaining, 60)
            print(f"  Cooldown:  {mins}m {secs}s remaining")
        else:
            print(f"  Cooldown:  complete (run `ytblock disable` to continue)")

    hosts_present = hosts_check()
    print(f"  Hosts:     {'present' if hosts_present else 'MISSING'}")
    print(f"  Video:     {'found' if os.path.exists(VIDEO_FILE) else 'missing'}")
    print(f"  Cert:      {'found' if os.path.exists(CERT_FILE) else 'missing'}")
    print()


