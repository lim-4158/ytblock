def main():
    # Handle internal commands (not exposed in help)
    # These are only valid when invoked by the script itself (serve, reblock_timer)
    # or after the friction process has set the unblock state (_unblock_hosts).
    if len(sys.argv) >= 2:
        if sys.argv[1] == "serve":
            run_server()
            return
        if sys.argv[1] == "_unblock_hosts":
            # Only allow if state shows an active unblock window
            state = load_state()
            if state.get("unblock_until") and not state.get("blocked", True):
                cmd_unblock_hosts()
            else:
                print("  Error: unblock not authorized. Use `ytblock disable`.")
                sys.exit(1)
            return
        if sys.argv[1] == "_reblock_timer" and len(sys.argv) >= 3:
            try:
                seconds = int(sys.argv[2])
                if seconds < 0:
                    seconds = 0
            except ValueError:
                print("  Error: invalid timer value.")
                sys.exit(1)
            cmd_reblock_timer(seconds)
            return
        if sys.argv[1] == "_reblock_hosts":
            cmd_reblock_hosts()
            return

    parser = argparse.ArgumentParser(
        description="ytblock \u2014 YouTube addiction blocker for macOS",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            examples:
              sudo ytblock install     Set up everything
              ytblock status           Check if YouTube is blocked
              ytblock disable          Start 5-step unblock process
              sudo ytblock enable      Re-block YouTube
              sudo ytblock uninstall   Remove everything
        """),
    )
    subparsers = parser.add_subparsers(dest="command")

    subparsers.add_parser("install", help="Full first-time setup (requires sudo)")
    subparsers.add_parser("uninstall", help="Remove everything (requires sudo)")
    subparsers.add_parser("enable", help="Re-block YouTube (requires sudo)")
    subparsers.add_parser("disable", help="5-step friction-based unblock process")
    subparsers.add_parser("status", help="Show current status")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    commands = {
        "install": cmd_install,
        "uninstall": cmd_uninstall,
        "enable": cmd_enable,
        "disable": cmd_disable,
        "status": cmd_status,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
